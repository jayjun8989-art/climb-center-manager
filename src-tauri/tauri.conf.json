{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClimbCenterManager",
  "version": "1.0.74",
  "identifier": "com.rabbg.climb-center-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "클라이밍 센터 회원관리",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "backgroundColor": "#f4f7fb"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "클라이밍 센터 회원관리",
    "longDescription": "ONCLE / GRABIT 클라이밍 센터 회원·출석·만료 관리 프로그램",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "Korean",
          "English"
        ],
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "클라이밍 센터"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5MTUyMDIyN0RGRTAwQjUKUldTMUFQNTlJaUFWdVYvZUhUS0w1aVBIb2lTSS9iVjYyVVhlblBMT1Y0SWFiRVVhQzl0TjVwVGQK",
      "endpoints": [
        "https://github.com/jayjun8989-art/climb-center-manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
