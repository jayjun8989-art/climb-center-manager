# Supabase (Dashboard > Project Settings > API)
#
# SECURITY
# - Use the anon (public) key ONLY in this desktop app.
# - NEVER put service_role here or in any VITE_* variable.
# - service_role belongs only on a trusted server / CI secret store, not in Tauri/React.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: first admin account (create manually in Supabase Auth)
# VITE_SUPABASE_DEFAULT_CENTER=ONCLE
