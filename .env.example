# Supabase (Dashboard > Project Settings > API)
#
# SECURITY
# - Use publishable key (sb_publishable_...) or legacy anon JWT ONLY.
# - NEVER put sb_secret_ / service_role here or in any VITE_* variable.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: first admin account (create manually in Supabase Auth)
# VITE_SUPABASE_DEFAULT_CENTER=ONCLE
#
# Excel export: only accounts in ADMIN_EXPORT_EMAILS (src/lib/exportPermissions.ts)
# Default: grabon@oncle.local — staff/oncle/grabit cannot create or open roster Excel files.

# --- Tauri updater signing (build machine only, NOT in Vite) ---
# Generate keys once (interactive password):
#   npm run tauri -- signer generate -w .\keys\tauri-update.key
# Public key is in src-tauri/tauri.conf.json (plugins.updater.pubkey).
#
# Signed release build (setup.exe + .sig):
#   npm run tauri:build
#   (prompts for keys\tauri-update.key password, or set env below first)
#
# Optional: avoid password prompt each build (PowerShell session only):
#   $env:TAURI_SIGNING_PRIVATE_KEY_PASSWORD = "your-key-password"
#   npm run tauri:build
#
# Plain build without updater signing:
#   npm run tauri:build:plain
#
# Upload to GitHub Release:
#   - ClimbCenterManager_x.x.x_x64-setup.exe
#   - ClimbCenterManager_x.x.x_x64-setup.exe.sig
#   - latest.json (see updater/latest.json.example)
